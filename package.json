{
  "name": "rapid-cmi5",
  "version": "0.7.0",
  "private": true,
  "email": "aaron.crawford@bylight.com",
  "scripts": {
    "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\"",
    "bp": "node utils/player-replacer.js",
    "build:player-for-editor": "bash scripts/buildCmi5PlayerForEditor.sh",
    "load:course-for-test": "bash scripts/loadCourseForPlayerTest.sh",
    "build-and-test-player": "bash scripts/buildAndTestPlayer.sh",
    "cmi5-builder": "nx run cmi5-builder:build",
    "cmi5-player": "nx run cc-cmi5-player:build",
    "postinstall": "electron-builder install-app-deps",
    "nxe:build:frontend": "nx build rapid-cmi5-electron-frontend --configuration=production",
    "nxe:build:backend": "nx build rapid-cmi5-electron --configuration=production",
    "nxe:serve:frontend": "nx serve rapid-cmi5-electron-frontend",
    "nxe:serve:backend": "nx serve rapid-cmi5-electron",
    "nxe:test:frontend": "nx test rapid-cmi5-electron-frontend",
    "nxe:test:backend": "nx test rapid-cmi5-electron",
    "nxe:package:app": "nx run rapid-cmi5-electron:make --prepackageOnly",
    "nxe:make:app": "nx run rapid-cmi5-electron:make",
    "nxe:e2e:chromium": "cross-env PW_PROJECT=chromium nx e2e rapid-cmi5-electron-frontend -- --project=chromium",
    "nxe:e2e:chromium:debug": "cross-env PW_PROJECT=chromium nx e2e rapid-cmi5-electron-frontend -- --project=chromium --headed --workers=1 --reporter=list",
    "nxe:e2e:chromium:ui": "cross-env PW_PROJECT=chromium nx e2e rapid-cmi5-electron-frontend -- --project=chromium --ui",
    "nxe:e2e:electron": "nx e2e rapid-cmi5-electron-frontend -- --project=electron",
    "nxe:e2e:all": "nx e2e rapid-cmi5-electron-frontend",
    "nxe:e2e:report": "playwright show-report dist/.playwright/apps/rapid-cmi5-electron-frontend/playwright-report",
    "nxe:e2e:codegen": "playwright codegen --target=playwright-test http://127.0.0.1:4200",
    "nxe:e2e:record": "cross-env PW_PROJECT=chromium nx e2e rapid-cmi5-electron-frontend -- --project=chromium --headed --workers=1 -g \"recording stub\"",
    "player:e2e": "nx e2e cc-cmi5-player-e2e",
    "player:e2e:debug": "nx e2e cc-cmi5-player-e2e -- --project=chromium --headed --workers=1 --reporter=list",
    "player:e2e:ui": "nx e2e cc-cmi5-player-e2e -- --project=chromium --ui",
    "player:e2e:report": "playwright show-report dist/.playwright/apps/cc-cmi5-player-e2e/playwright-report"
  },
  "browserslist": [
    "last 2 chrome versions",
    "last 2 edge versions",
    "last 2 firefox versions",
    "last 2 safari versions"
  ],
