{
  "name": "cc-cmi5-player-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cc-cmi5-player-e2e/src",
  "projectType": "application",
  "tags": [],
  "implicitDependencies": ["cc-cmi5-player"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": [
        "{workspaceRoot}/dist/.playwright/apps/cc-cmi5-player-e2e"
      ],
      "options": {
        "config": "apps/cc-cmi5-player-e2e/playwright.config.ts"
      },
      "configurations": {
        "chromium": {
          "project": ["chromium"]
        },
        "chromium-debug": {
          "project": ["chromium"],
          "headed": true,
          "workers": 1,
          "reporter": "list"
        },
        "chromium-ui": {
          "project": ["chromium"],
          "ui": true
        },
        "smoke": {
          "project": ["chromium"],
          "grep": "@smoke"
        },
        "navigation": {
          "project": ["chromium"],
          "grep": "@navigation"
        },
        "content": {
          "project": ["chromium"],
          "grep": "@content"
        },
        "activities": {
          "project": ["chromium"],
          "grep": "@activities"
        }
      },
      "metadata": {
        "description": "Run Playwright E2E tests against the CMI5 player",
        "technologies": ["playwright"]
      }
    },
    "e2e-report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright show-report dist/.playwright/apps/cc-cmi5-player-e2e/playwright-report"
      },
      "metadata": {
        "description": "Open the most recent Playwright HTML report for the player suite"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
