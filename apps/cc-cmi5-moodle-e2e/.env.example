# Copy to repo-root .env.local (gitignored) and fill in. The Moodle
# playwright.config loads .env then .env.local (local overrides). See
# docs/moodle-player-e2e-strategy.md for what each is and where to get it.

# --- Moodle site + target activity ---
MOODLE_BASE_URL=https://moodle5.develop-cp.rangeos.engineering
MOODLE_ACTIVITY_ID=737

# --- Browser login (e2e bot admin account) ---
MOODLE_BOT_USER=
MOODLE_BOT_PASS=

# --- Web-service upload (provisioning, phase 3) ---
# MOODLE_WS_TOKEN=
# MOODLE_COURSE_ID=
# MOODLE_SECTION_ID=

# --- AU -> scenario mappings (scenarios only) ---
# JWT_DEVOPS_API=
