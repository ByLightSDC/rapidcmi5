# Copy to repo-root .env.local (gitignored) and fill in. The Moodle
# playwright.config loads .env then .env.local (local overrides). See
# docs/moodle-player-e2e-strategy.md for what each is and where to get it.

# --- Moodle site + target activity ---
MOODLE_BASE_URL=https://moodle5.develop-cp.rangeos.engineering
MOODLE_ACTIVITY_ID=737

# --- Browser login (e2e bot admin account) ---
MOODLE_BOT_USER=
MOODLE_BOT_PASS=

# --- Web-service upload (provisioning, phase 3) ---
# MOODLE_WS_TOKEN=
# MOODLE_COURSE_ID=
# MOODLE_SECTION_ID=

# --- rangeos-api deploy auth (@scenario lane: class/team scenario deploy) ---
# Preferred: mint the token in-test via Keycloak password grant from the bot
# creds (self-renewing; deploy user == launch user so team range lookups work).
# rangeos-dashboard is a PUBLIC client w/ Direct Access Grants — no secret.

KEYCLOAK_BOT_USER=e2e-rc5-bot@bylight.com
KEYCLOAK_BOT_PASS=
KEYCLOAK_BOT_USER=
KEYCLOAK_BOT_PASS=
