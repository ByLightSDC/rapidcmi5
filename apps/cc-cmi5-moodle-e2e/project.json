{
  "name": "cc-cmi5-moodle-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cc-cmi5-moodle-e2e/src",
  "projectType": "application",
  "tags": [],
  "implicitDependencies": ["cc-cmi5-player", "cmi5-builder"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{workspaceRoot}/dist/.playwright/apps/cc-cmi5-moodle-e2e"],
      "options": {
        "config": "apps/cc-cmi5-moodle-e2e/playwright.config.ts"
      },
      "configurations": {
        "chromium": {
          "project": ["chromium"],
          "grepInvert": "@scenario"
        },
        "chromium-debug": {
          "project": ["chromium"],
          "headed": true,
          "workers": 1,
          "reporter": "list",
          "grepInvert": "@scenario"
        },
        "chromium-ui": {
          "project": ["chromium"],
          "ui": true
        },
        "launch": {
          "project": ["chromium"],
          "grep": "@launch"
        },
        "scenario": {
          "project": ["chromium"],
          "grep": "@scenario"
        },
        "scenario-debug": {
          "project": ["chromium"],
          "grep": "@scenario",
          "headed": true,
          "workers": 1,
          "reporter": "list"
        }
      },
      "metadata": {
        "description": "Run Playwright E2E tests against the CMI5 player launched through Moodle",
        "technologies": ["playwright"]
      }
    },
    "e2e-report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright show-report dist/.playwright/apps/cc-cmi5-moodle-e2e/playwright-report"
      },
      "metadata": {
        "description": "Open the most recent Playwright HTML report for the Moodle suite"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
